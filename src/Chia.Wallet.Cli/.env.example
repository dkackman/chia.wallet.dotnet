# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
CHIA_PEER_HOST=wss://your-node.example.com:8444
CHIA_NETWORK_ID=mainnet
# Wallet key — provide ONE of the following:
CHIA_MNEMONIC=word1 word2 ... word24
# CHIA_SECRET_KEY=<hex-encoded secret key>
# CHIA_PUBLIC_KEY=<hex-encoded public key (read-only, cannot sign transactions)>

# TLS client certificate — provide EITHER file paths OR PEM strings.
# File paths (e.g. ~/.chia/mainnet/config/ssl/full_node/private_full_node.crt)
CHIA_CERT_PATH=/path/to/cert.crt
CHIA_KEY_PATH=/path/to/cert.key

# Or inline PEM strings (useful for CI/containers where files aren't available)
# CHIA_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# CHIA_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
